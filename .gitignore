# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log* 

# env files (can opt-in for committing if needed)
.env
.env.local
.env.development
.env.production
.env.development.local
.env.production.local
.env.staging
.env.test
# .env.example is intentionally NOT ignored — commit it as a template

# secrets & credentials — catch-all for any stray credential files
*.key
*.p12
*.pfx
*.cert
*.keystore
secrets.*
credential*
*.cred

# docker (may contain env vars)
/docker-compose.override.yml
/docker-compose.override.yaml

# local editor / OS
/.vscode
/.idea
.DS_Store
*.log

# AI / chat / prompt metadata
.ai
*.prompt*
*.history
*.session
.copilot*
.claude*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

/public/uploads

# audit / dependency lock file backups
package-lock.json.bak
yarn.lock.bak

AGENTS.md
CLAUDE.md